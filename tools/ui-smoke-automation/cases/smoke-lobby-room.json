            }
          ],
          "expect_log": {
            "event_name": "GameRoom",
            "function_name": "MoreGame",
            "page_name": "GameRoom",
            "game_id": "31"
          },
          "log_timeout_ms": 12000
        }
      ],
      "assertions": {
        "log": {
          "expect": {
            "event_name": "GameRoom",
            "function_name": "MoreGame",
            "page_name": "GameRoom",
            "game_id": "31"
          },
          "jsondata_required_keys": [
            "table",
            "round_number"
          ]
        }
      }
    }
  ]
}
