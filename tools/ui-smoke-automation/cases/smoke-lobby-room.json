            "world_position": {
              "x": 432,
              "y": 1072.95
            },
            "size": {
              "width": 814,
              "height": 334
            },
            "point_offsets_px": [
              { "dx": 0, "dy": 0 },
              { "dx": -120, "dy": 0 },
              { "dx": 120, "dy": 0 },
              { "dx": 0, "dy": -60 },
              { "dx": 0, "dy": 60 }
            ]
          },
          "scan_grid": {
            "enabled": false,
            "x_min": 0.44,
            "x_max": 0.56,
            "y_min": 0.25,
            "y_max": 0.36,
            "x_steps": 5,
            "y_steps": 4,
