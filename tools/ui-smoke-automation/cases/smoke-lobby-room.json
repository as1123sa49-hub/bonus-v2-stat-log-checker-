          "points": [
            {
              "x": 0.938,
              "y": 0.939
            },
            {
              "x": 0.926,
              "y": 0.939
            },
            {
              "x": 0.95,
              "y": 0.939
            },
            {
              "x": 0.938,
              "y": 0.928
            },
            {
              "x": 0.938,
