{
  "name": "qa-tools-monorepo",
  "version": "2.0.0",
  "private": true,
  "description": "QA 工具 monorepo：tools-hub 整合入口 + tools（500X V2、log 攔截／比對、圖比、測案產生、smoke 等）",
  "scripts": {
    "start:bonus-v2": "node tools/bonus-v2/server.js",
    "start:500x": "node tools/bonus-v2/server.js",
    "test": "npx playwright test",
    "test:it": "npx playwright test tests/integration",
    "test:reg": "npx playwright test tests/regression",
    "test:ui-smoke": "node tools/ui-smoke-automation/run-smoke.js",
    "report": "npx playwright show-report reports/playwright",
    "clean": "powershell -ExecutionPolicy Bypass -File .\\clean.ps1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.56.0"
  },
  "dependencies": {
    "express": "^4.21.0",
    "playwright-core": "^1.49.0"
  }
}
